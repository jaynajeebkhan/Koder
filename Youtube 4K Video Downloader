@app.route('/assets/<path:filename>')
def serve_assets(filename):
    return send_from_directory(ASSET_FOLDER, filename)

@app.route('/analyze_platform', methods=['POST'])
def analyze_platform():
    url = request.json.get('url')
    cookie_path = 'cookies.txt'
    
    ydl_opts = {
        'quiet': True,
        'noplaylist': True,
        'user_agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/121.0.0.0 Safari/537.36',
        'nocheckcertificate': True,
        'socket_timeout': 30,
    }
    
    if os.path.exists(cookie_path):
        ydl_opts['cookiefile'] = cookie_path

    try:
        with yt_dlp.YoutubeDL(ydl_opts) as ydl:
            info = ydl.extract_info(url, download=False)
            
            domain = url.lower()
            platform = "WEB SOURCE"
            if "youtube" in domain or "youtu.be" in domain: platform = "YOUTUBE"
            elif "instagram" in domain: platform = "INSTAGRAM"
            elif "twitter" in domain or "x.com" in domain: platform = "X / TWITTER"
            elif "facebook" in domain: platform = "FACEBOOK"
            elif "pinterest" in domain: platform = "PINTEREST"

            formats = []
            seen = set()
            for f in reversed(info.get('formats', [])):
                res = f.get('height')
                if res and res not in seen and f.get('vcodec') != 'none':
                    label = f"{res}p"
                    if res >= 2160: label = "4K UHD"
                    formats.append({'id': f['format_id'], 'label': label, 'ext': 'mp4'})
                    seen.add(res)
            
            if not formats:
                formats.append({'id': 'best', 'label': 'Production Master', 'ext': 'mp4'})

            return jsonify({
                'title': info.get('title', 'Untitled Production'),
                'thumbnail': info.get('thumbnail', '/assets/logo.png'),
                'platform': platform,
                'formats': formats[:6]
            })
    except Exception as e:
        return jsonify({'error': str(e)}), 400

@app.route('/download', methods=['POST'])
def download_video():
    url = request.form.get('url')
    format_id = request.form.get('format_id')
    cookie_path = 'cookies.txt'
    
    ydl_opts = {
        'format': f'{format_id}+bestaudio/best' if format_id != 'best' else 'best',
        'outtmpl': f'{DOWNLOAD_FOLDER}/Download by Koder | %(title)s.%(ext)s',
        'merge_output_format': 'mp4',
        'user_agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/121.0.0.0 Safari/537.36',
        'quiet': True,
    }

    if os.path.exists(cookie_path):
        ydl_opts['cookiefile'] = cookie_path

    try:
        with yt_dlp.YoutubeDL(ydl_opts) as ydl:
            info = ydl.extract_info(url, download=True)
            filename = ydl.prepare_filename(info)
            final_path = filename.rsplit('.', 1)[0] + '.mp4'
            return send_file(final_path, as_attachment=True)
    except Exception as e:
        return f"Extraction failed: {e}"

